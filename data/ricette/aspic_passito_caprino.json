            "unita_descrizione": "Per la panna cotta di caprino"
        },
        {
            "quantita": 180,
            "unita_descrizione": "g Formaggio caprino fresco"
        },
        {
            "quantita": 80,
            "unita_descrizione": "g Panna"
        },
        {
            "quantita": 40,
            "unita_descrizione": "g Latte intero fresco"
        },
        {
            "quantita": 5,
            "unita_descrizione": "g Colla di pesce"
        },
        {
            "quantita": null,
            "unita_descrizione": "Finocchio selvatico"
        },
        {
