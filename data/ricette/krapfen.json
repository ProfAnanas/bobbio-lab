{
    "id": "krapfen",
    "titolo": "Krapfen",
    "nota_dosi": "per 15 krapfen (si possono fare anche a ciambella)",
    "ingredienti": [
        {
            "quantita": 300,
            "unita_descrizione": "g Farina forte (Manitoba)"
        },
        {
