            "unita_descrizione": "g Uova"
        },
        {
            "quantita": 150,
            "unita_descrizione": "g Acqua"
        },
        {
            "quantita": 40,
            "unita_descrizione": "g Zucchero"
        },
        {
            "quantita": 40,
            "unita_descrizione": "g Burro morbido"
        },
        {
            "quantita": 20,
            "unita_descrizione": "g Lievito di birra fresco"
        },
        {
            "quantita": 7,
            "unita_descrizione": "g Sale fino"
        },
        {
            "quantita": 1,
            "unita_descrizione": "g Baking"
        },
        {
            "quantita": null,
            "unita_descrizione": "Aromi a piacere (vaniglia, limone, arancia, ecc.)"
        },
        {
            "quantita": null,
            "unita_descrizione": "Per friggere"
        },
        {
            "quantita": 2,
            "unita_descrizione": "l Olio di semi per frittura"
        },
        {
            "quantita": 200,
            "unita_descrizione": "g Zucchero semolato (per copertura)"
        }
    ],
    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Nella ciotola della planetaria munita di gancio inserire: farina, uova ed acqua.\nCominciare a impastare a velocità bassa fino ad amalgamare gli ingredienti.",
            "icona": "gancio",
            "velocita": "bassa"
        },
        {
            "step_id": "step-2",
            "testo": "Aggiungere lo zucchero ed il sale",
            "icona": "aggiungere",
            "velocita": "media"
        },
        {
            "step_id": "step-3",
            "testo": "Aggiungere il lievito sciolto in un cucchiaio di acqua",
            "icona": "aggiungere",
            "tempo": "10 sec.",
            "velocita": "media"
        },
        {
            "step_id": "step-4",
            "testo": "Aggiungere il burro, il baking e gli aromi. Far girare l'impasto fino a che non risulterà ben incordato.",
            "icona": "gancio",
            "velocita": "media-alta"
        },
        {
            "step_id": "step-5",
            "testo": "Rovesciare l'impasto sul banco da lavoro, pirlare, trasferire in un contenitore leggermente unto e coprire con pellicola.",
            "icona": "impastare_mano"
        },
        {
            "tipo": "bivio",
            "rami": [
                {
                    "step_id": "step-6a",
                    "testo": "Far lievitare a 26-28°C fino a raddoppio del volume (circa 1 ora e mezza / due ore)",
                    "icona": "lievitazione",
                    "temperatura": "26-28°C",
                    "tempo": "1.5-2 ore."
                },
                {
                    "step_id": "step-6b",
                    "testo": "Far riposare a temperatura ambiente per 30 minuti.\nMettere quindi a fermentare in frigorifero per 8-12 ore.",
                    "icona": "frigorifero",
                    "temperatura": "+4°C",
                    "tempo": "8-12 ore."
                }
            ]
        },
        {
            "step_id": "step-7",
            "testo": "Se l'impasto ha lievitato subito senza il passaggio in frigorifero, inserire il contenitore con l'impasto caldo in abbattitore per circa 10-15 minuti.",
            "opzionale": true,
            "icona": "frigorifero",
            "temperatura": "+4°C",
            "tempo": "10-15 min."
        },
        {
            "step_id": "step-8",
            "testo": "Stendere il panetto sul piano di lavoro con uno spolvero di farina a 3,5 mm. Coppare con lo stampo da 7 cm e disporre su una teglia rivestita di carta da forno.",
            "icona": "forma",
            "dimensione": "H 3,5mm. diametro 7cm"
        },
        {
            "step_id": "step-9",
            "testo": "Fare lievitare fino al raddoppio (circa 90 min)",
            "icona": "lievitazione",
            "temperatura": "26-28°C",
            "tempo": "90 min."
        },
        {
            "tipo": "parallelo",
            "rami": [
                {
                    "step_id": "step-10a",
                    "testo": "Ritagliare la carta da forno su cui sono poggiati i krapfen",
                    "icona": "tagliare"
                },
                {
                    "step_id": "step-10b",
                    "testo": "In un pentolino alto, scaldare l'olio a 170°C",
                    "icona": "pentolino",
                    "temperatura": "170°C"
                }
            ]
        },
        {
            "step_id": "step-11",
            "testo": "Immergere i krapfen con il quadrato di carta da forno nell'olio, dopo qualche secondo, con l'aiuto di una pinza, togliere la carta e proseguire la cottura fino a che non saranno ben dorati da entrambi i lati.",
            "icona": "pentolino"
        },
        {
            "step_id": "step-12",
            "testo": "Scolare su carta assorbente e passare il krapfen ancora caldo nello zucchero semolato.",
            "icona": "spennellare"
        }
    ]
}