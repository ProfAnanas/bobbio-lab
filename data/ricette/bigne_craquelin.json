    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Per il craquelin: mescolare il burro morbido con lo zucchero fino a ottenere un composto omogeneo.",
            "icona": "mescolare"
        },
        {
            "step_id": "step-2",
            "testo": "Aggiungere la farina e lavorare velocemente fino a ottenere un impasto liscio.",
            "icona": "mescolare"
        },
        {
            "step_id": "step-3",
            "testo": "Stendere l'impasto tra due fogli di carta forno con uno spessore di circa 1-2 mm",
            "icona": "mattarello",
            "dimensione": "1-2 mm"
        },
        {
            "step_id": "step-4",
            "testo": "Congelare per almeno 30 minuti, finché non è ben duro.",
            "icona": "abbattitore",
            "temperatura": "-18°C",
            "tempo": "30 min."
        },
        {
            "step_id": "step-5",
            "testo": "Coppare con un tagliapasta leggermente più grande dei bignè dressati.",
            "icona": "porzionare"
        },
        {
            "step_id": "step-6",
            "testo": "Per i bignè: portare a bollore l'acqua, il latte, il burro, il sale e lo zucchero.",
            "icona": "pentolino",
            "temperatura": "100°C"
        },
        {
            "step_id": "step-7",
            "testo": "Unire la farina setacciata in un colpo solo e cuocere il polentino per 1 minuto.",
            "icona": "pentolino",
            "tempo": "1 min."
        },
        {
            "step_id": "step-8",
            "testo": "Trasferire nel cutter e fare girare fino a raggiungere circa 50 °C.",
            "icona": "mixer",
            "temperatura": "50°C"
        },
        {
            "step_id": "step-9",
            "testo": "Unire quindi le uova fino a che l'impasto raggiunge la consistenza corretta (il composto deve “nastrare”, creando il solito triangolo che scende piano ma non a pezzi grandi).",
            "icona": "mixer"
        },
        {
            "step_id": "step-10",
            "testo": "Dressare con la bocchetta liscia, diametro 8mm, e adagiare il craquelin sul singolo bignè.",
            "icona": "sac"
        },
        {
            "step_id": "step-11",
            "testo": "Cuocere in forno statico con valvola chiusa per 8 minuti a 200 °C",
            "icona": "forno_statico",
            "temperatura": "200°C",
            "tempo": "8 min."
        },
        {
            "step_id": "step-12",
            "testo": "Proseguire la cottura per 9 minuti a 180 °C",
            "icona": "forno_statico",
            "temperatura": "180°C",
            "tempo": "9 min."
        },
        {
            "step_id": "step-13",
            "testo": "Proseguire la cottura per 5 minuti a 170°C.",
            "icona": "forno_statico",
            "temperatura": "170°C",
            "tempo": "5 min."
        }
    ]
}