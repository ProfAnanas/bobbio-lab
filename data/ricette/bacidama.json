            "temperatura": "+4°C"
        },
        {
            "step_id": "step-3",
            "testo": "Realizzare delle palline identiche tra loro, di 5-6 g di peso",
            "icona": "porzionare",
            "dimensione": "5-6 g"
        },
        {
            "step_id": "step-4",
            "testo": "Per fare tutte le palline uguali, stendere l'impasto ad altezza 1 cm e tagliare tanti tondini uguali con un coppapasta e poi arrotolare per creare la pallina.",
