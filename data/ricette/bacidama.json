            "testo_nodo": "ATTENZIONE"
        },
        {
            "step_id": "step-5",
            "testo": "Congelare le palline",
            "icona": "abbattitore",
            "temperatura": "-18°C"
        },
        {
            "step_id": "step-6",
            "testo": "Cuocere per 8-10 minuti a 160°C",
            "icona": "forno_statico",
            "temperatura": "160°C",
            "tempo": "8-10 min."
        },
        {
            "step_id": "step-7",
            "testo": "Farcire ogni semisfera con un po’ di cioccolato temperato (o sciolto in microonde/bagnomaria) e dopo qualche secondo accoppiare con un’altra semisfera."
