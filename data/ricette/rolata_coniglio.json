        },
        {
            "step_id": "step-9",
            "testo": "Per la salsa sarà necessario frullare il fondo di cottura ed eventualmente legarlo",
            "icona": "pimer"
        },
        {
            "step_id": "step-10",
            "testo": "Tagliare la rolata a fette spesse 1,5-2 cm e dressarla sul piatto con la sua salsa",
