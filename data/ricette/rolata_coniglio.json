        {
            "step_id": "step-5",
            "testo": "Con le verdure fare una mirepoix magra.",
            "icona": "tagliare"
        },
        {
            "step_id": "step-6",
            "testo": "Cuocere in forno o in casseruola. Fare prima un passaggio a temperatura elevata (per rosolare) e poi moderare la temperatura. Se necessario bagnare di tanto in tanto con fondo vegetale.",
