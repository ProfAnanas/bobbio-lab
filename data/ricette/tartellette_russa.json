    ],
    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Stendere la frolla a 2-3mm quindi rivestire gli stampi imburrati e infarinati e bucherellare con una forchetta.",
            "icona": "mattarello",
            "dimensione": "2-3 mm"
        },
        {
            "step_id": "step-2",
            "testo": "Cuocere in forno statico a 180°C per 15-20 min.",
            "icona": "forno_statico"
        },
        {
            "tipo": "parallelo",
            "rami": [
                {
                    "step_id": "step-3a",
                    "testo": "Tagliare le patate e le carote a dadini di 5mm",
                    "icona": "tagliare"
                },
                {
                    "step_id": "step-3b",
                    "testo": "Tagliare a dadini i cetriolini e i funghetti"
                }
            ]
        },
        {
            "tipo": "parallelo",
            "rami": [
                {
                    "step_id": "step-4a",
                    "testo": "Sbollentare patate, carote e piselli per qualche minuto in acqua salata quindi raffreddare in acqua e ghiaccio",
                    "icona": "pentolino"
                },
                {
                    "step_id": "step-4b",
                    "testo": "Sminuzzare il tonno",
                    "icona": "tagliare"
                }
            ]
        },
        {
            "step_id": "step-5",
            "testo": "Raccogliere tutti gli ingredienti in una ciotola e condire con maionese, worcester e aggiustare di sale.",
            "icona": "mescolare"
        },
        {
            "step_id": "step-6",
            "testo": "Pulire i gamberi (conservare il codino) e frullare insieme al petto di pollo tagliato a pezzi, al pane e al ghiaccio.",
            "icona": "mixer"
        },
        {
            "step_id": "step-7",
            "testo": "Unire l'albume, un pizzico di sale e pepe, il coriandolo tritato e lo zenzero grattugiato.",
            "icona": "mescolare"
        },
        {
            "step_id": "step-8",
            "testo": "Formare delle piccole crocchette (grandi da stare dentro la tartelletta) quindi impanare con uovo e pangrattato. Infilare il codino del gambero (opzionale)",
            "icona": "forma"
        },
        {
            "step_id": "step-9",
            "testo": "Friggere in olio bollente a 170°C fino a doratura.",
            "icona": "pentolino",
            "temperatura": "170°C"
        },
        {
            "step_id": "step-10",
            "testo": "Comporre la tartelletta: riempire con l'insalata russa, farcire il bordo con la maionese quindi appoggiare una crocchetta di gamberi fritta."
        }
    ]
}