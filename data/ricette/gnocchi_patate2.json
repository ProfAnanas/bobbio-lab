        },
        {
            "step_id": "step-5",
            "testo": "Aggiungere insieme alla farina i tuorli d'uovo se previsti",
            "opzionale": true,
            "icona": "impastare_mano"
        },
        {
            "step_id": "step-6",
            "testo": "Formare dei filoncini di 2 cm di circonferenza, con l’aiuto del palmo delle mani",
            "icona": "impastare_mano"
        },
        {
            "step_id": "step-7",
            "testo": "Con  una  spatola, sempre sul  tavolo infarinato, tagliare degli gnocchi della lunghezza di 2 cm quindi pressare sui rebbi di una forchetta o sul retro di una grattugia, per formare delle righe o dei puntini.",
            "icona": "tagliare",
            "dimensione": "2 cm"
        },
        {
            "step_id": "step-8",
            "testo": "Versare gli gnocchi in acqua bollente salata",
            "icona": "pentola_alta"
        },
        {
            "tipo": "bivio",
            "rami": [
                {
                    "step_id": "step-9a",
                    "testo": "Scolare,  quando  vengono  a  galla,  direttamente  in  padella con la salsa desiderata e saltare",
                    "icona": "padella"
                },
                {
                    "step_id": "step-9b",
                    "testo": "Scolare  quando  vengono  a  galla  in  una  bowl  con  acqua fredda, oppure scolare in una teglia unta d’olio da far raffreddare in abbattitore.",
                    "icona": "microonde"
                }
            ]
        },
        {
            "step_id": "step-10",
            "testo": "Se immersi in acqua fredda, scolare, ungere con olio di semi di girasole e versare in una teglia.",
            "condizione": "b",
            "icona": "versare"
        },
        {
            "step_id": "step-11",
            "testo": "Coprire  la  teglia e conservare in frigorifero a +3°C per 2 giorni. Oppure riempire dei sacchetti e conservare in atmosfera modificata per 20 giorni circa.",
            "icona": "frigorifero",
            "temperatura": "+3°C"
        }
    ]
