    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Lavare e cuocere le patate a vapore (60/80 minuti)",
            "icona": "forno_vapore",
            "tempo": "60-80 min."
        },
        {
            "step_id": "step-2",
            "testo": "Cuocere a vapore anche l'ortaggio scelto",
            "opzionale": true,
            "icona": "forno_vapore"
