        },
        {
            "tipo": "parallelo",
            "rami": [
                {
                    "step_id": "step-2a",
                    "testo": "Inserire le uova una alla volta. (non aggiungere il successivo finché il precedente non è assorbito).",
                    "icona": "aggiungere",
                    "velocita": "media"
                },
                {
                    "step_id": "step-2b",
                    "testo": "Setacciare farina e baking due volte.",
                    "icona": "setacciare"
                }
            ]
        },
        {
            "step_id": "step-3",
            "testo": "Incorporare le polveri a mano con una marisa, mescolando solo il tempo necessario a bagnare la farina. (Non lavorare troppo l’impasto, se si sviluppa glutine, il cake diventerà gommoso)",
            "icona": "mescolare"
        },
        {
            "step_id": "step-4",
            "testo": "Imburrare e infarinare lo stampo e cuocere a 165°C ventilato per circa 40-50 min (prova stecchino). La temperatura al cuore deve raggiungere i 96-98°C.",
