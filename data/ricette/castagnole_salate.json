    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "In un pentolino portare a bollore: acqua, burro, maltitolo.",
            "icona": "pentolino",
            "temperatura": "100°C"
        },
        {
            "step_id": "step-2",
            "testo": "Aggiungere la farina e cuocere il polentino finché non si stacca dalle pareti.",
            "icona": "pentolino"
        },
        {
            "step_id": "step-3",
            "testo": "Trasferire nella planetaria munita di foglia e aggiungere le uova, una alla volta.",
            "icona": "foglia"
        },
        {
            "step_id": "step-4",
            "testo": "Aggiungere i 30g di farina miscelata con una punta di ammoniaca per dolci."
        },
        {
            "step_id": "step-5",
            "testo": "Tagliare tutte le verdure e la mozzarella a dadini.",
            "icona": "tagliare"
        },
        {
            "step_id": "step-6",
            "testo": "Unire le verdure, la mozzarella, il parmigiano e un pizzico di peperoncino alla pasta choux quindi aggiustare di sale e pepe.",
            "icona": "aggiungere"
        },
        {
            "step_id": "step-7",
            "testo": "Trasferite in un sac-à-poche con la bocchetta liscia e abbastanza grande da far passare i dadini di verdura.",
            "icona": "sac",
            "dimensione": "bocchetta liscia"
        },
        {
            "step_id": "step-8",
            "testo": "Friggere piccole porzioni in olio a 150°C fino a doratura.",
            "icona": "padella",
            "temperatura": "150C°"
        },
        {
            "step_id": "step-9",
            "testo": "Farcire con crema pasticcera salata e spolverizzare con sale e peperoncino.",
