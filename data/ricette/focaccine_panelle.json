        },
        {
            "quantita": 20,
            "unita_descrizione": "g Olio EVO"
        },
        {
            "quantita": null,
            "unita_descrizione": "Rosmarino tritato"
        },
        {
            "quantita": null,
            "unita_descrizione": "Sale grosso e pepe"
        },
        {
            "quantita": null,
            "unita_descrizione": "Per le panelle"
        },
        {
            "quantita": 40,
            "unita_descrizione": "g Farina di ceci"
        },
        {
            "quantita": 160,
            "unita_descrizione": "g Acqua"
        },
        {
            "quantita": 4,
            "unita_descrizione": "g Olio EVO"
        },
        {
            "quantita": null,
            "unita_descrizione": "Sale e pepe"
        }
    ],
    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Impastare a mano: farina di kamut, farina, biga, lievito, 80g di acqua per 20 minuti.",
            "icona": "impastare_mano"
        },
        {
            "step_id": "step-2",
            "testo": "Aggiungere poco alla volta la restante acqua, l'olio e infine il sale",
            "icona": "impastare_mano"
        },
        {
            "step_id": "step-3",
            "testo": "Lasciar lievitare a 26-28°C in un contenitore per 20 minuti.",
            "icona": "lievitazione",
            "temperatura": "26-28°C"
        },
        {
            "step_id": "step-4",
            "testo": "Stendere l'impasto a uno spessore di 2cm quindi far riposare 10 minuti.",
            "icona": "mattarello",
            "tempo": "10 min riposo",
            "dimensione": "2cm"
        },
        {
            "step_id": "step-5",
            "testo": "Tagliare dei quadrati di 3,5cm di lato.",
            "icona": "forma",
            "dimensione": "3.5 cm lato"
        },
        {
            "step_id": "step-6",
            "testo": "Trasferire in teglia e far lievitare 1 ora.",
            "icona": "lievitazione",
            "temperatura": "26-28°C",
            "tempo": "1 ora"
        },
        {
            "step_id": "step-7",
            "testo": "Schiacciare con le dita le focaccine quindi condire con olio, sale grosso, rosmarino tritato e pepe.",
            "icona": "aggiungere"
        },
        {
            "step_id": "step-8",
            "testo": "Cuocere in forno a 250°C per 5 minuti.",
            "icona": "forno_statico",
            "temperatura": "250°C",
            "tempo": "5 min."
        },
        {
            "step_id": "step-9",
            "testo": "Per le panelle di ceci, amalgamare in una terrina tutti gli ingredienti previsti.",
            "icona": "montare"
        },
        {
            "step_id": "step-10",
            "testo": "Lasciar riposare la pastella 30 min a temperatura ambiente.",
            "icona": "riposo",
            "temperatura": "ambiente",
            "tempo": "30 min."
        },
        {
            "step_id": "step-11",
            "testo": "Mettere la terrina sul fuoco o trasferire la pastella in un pentolino quindi cuocere mescolando continuamente. Deve diventare una sorta di polenta. Quindi proseguire la cottura per 5 minuti.",
            "icona": "pentolino",
            "tempo": "fino a ispessimento"
        },
        {
            "step_id": "step-12",
            "testo": "Trasferire la polentina su un fogli odi carta da forno, coprire con un altro foglio quindi stendere ad uno spessore di 2mm.\nFar raffreddare",
            "icona": "mattarello",
            "dimensione": "2mm"
        },
        {
            "step_id": "step-13",
            "testo": "Ritagliare dei quadratini delle stesse dimensioni delle focaccine.",
            "icona": "forma"
        },
        {
            "step_id": "step-14",
            "testo": "Friggere in olio bollente a 170°C.",
            "icona": "padella",
            "temperatura": "170°C"
        },
        {
            "step_id": "step-15",
            "testo": "Tagliare a metà le focaccine, farcire con due panelle fritte ancora calde, fermare con uno stecchino e decorare con rosmarino fresco.",
            "icona": "sac"
        }
    ]
}